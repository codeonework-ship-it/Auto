# ============================================================================
# AutoHub — environment configuration (copy to .env for local dev)
# ----------------------------------------------------------------------------
# NOTE: The database password below is committed for LOCAL/DEV convenience only,
# as requested. In QA/UAT/PROD it MUST come from a secrets manager (Vault,
# AWS Secrets Manager, etc.) and never be committed. See docs/architecture/security-kyc.md
# ============================================================================

# ---- Active environment: Dev | QA | UAT | PROD ----
APP_ENV=Dev

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=automobiles
POSTGRES_PASSWORD=Automobiles_DB@12345
# Database is selected per environment: AutomobilesDB_Dev | _QA | _UAT | _PROD
POSTGRES_DB=AutomobilesDB_Dev

# ---- Backend (Spring Boot) ----
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
JWT_SECRET=change-me-in-prod-this-is-a-dev-only-256bit-secret-key-0123456789
JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=7

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
EVENTS_KAFKA_ENABLED=true

# ---- Frontend ----
WEB_APP_PORT=5173
CONTROL_PANEL_PORT=5174
VITE_API_BASE_URL=http://localhost:8080/api/v1
